{
  "name": "certidao-app",
  "version": "1.0.0",
  "description": "Hidro Forte - Emissão de Certidões Fiscais",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "keywords": [
    "certidao",
    "cnpj",
    "fiscal"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.hidroforte.certidoes",
    "productName": "Hidro Forte - Emissão de Certidões",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "portable": {
      "artifactName": "HidroForte-Certidoes.exe"
    },
    "files": [
      "src/**/*",
      "icon.png",
      "logo.png",
      "package.json",
      "node_modules/**/*",
      "!node_modules/puppeteer/.local-chromium/**/*",
      "!chrome-bundled/**/*"
    ],
    "extraResources": [
      {
        "from": "chrome-bundled",
        "to": "chrome-win64",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "firebase-admin": "^13.6.1",
    "iconv-lite": "^0.6.3",
    "node-capmonster": "^0.4.5",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^21.6.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
